{
  "permissions": {
    "additionalDirectories": [
      "/home/kim/.claude"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "robotcode-lsp@local-plugins": true
  },
  "extraKnownMarketplaces": {
    "local-plugins": {
      "source": {
        "source": "directory",
        "path": "/home/kim/.claude/plugins/local"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Boiling the ocean",
      "Yak shaving",
      "Eating the bear",
      "Sometimes the bear eats you",
      "He's going the distance... He's going for speed",
      "All your bAI belong to us",
      "The truth is out there",
      "Spinning plates",
      "Flying high",
      "Pulling strings",
      "Counting our chickens",
      "Getting ahead of ourselves",
      "Get to the choppa!",
      "Skynet booting"
    ]
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
